<div class="json-line">
    <span class="json-indent" style="padding-left: @IndentPx"></span>

    @if (IsCollapsible && Node.Children.Count > 0)
    {
        <button class="json-toggle" @onclick="ToggleCollapse" title="@(Node.IsCollapsed ? "Expand" : "Collapse")">
            @(Node.IsCollapsed ? "▶" : "▼")
        </button>
    }
    else
    {
        <span class="json-toggle-spacer"></span>
    }

    @if (Node.Key != null)
    {
        <span class="json-key">"@Node.Key"</span><span class="json-punct">:&nbsp;</span>
    }

    @if (IsCollapsible)
    {
        <span class="json-punct">@OpenBracket</span>
        @if (Node.IsCollapsed && Node.Children.Count > 0)
        {
            <span class="json-ellipsis" @onclick="ToggleCollapse">&nbsp;…&nbsp;</span>
            <span class="json-punct">@CloseBracket</span>
            @if (!IsLast)
            {
                <span class="json-punct">,</span>
            }
        }
        else if (Node.Children.Count == 0)
        {
            <span class="json-punct">@CloseBracket</span>
            @if (!IsLast)
            {
                <span class="json-punct">,</span>
            }
        }
    }
    else if (Node.NodeType == JsonNodeType.String)
    {
        <span class="json-string">"@Node.StringValue"</span>
        @if (!IsLast)
        {
            <span class="json-punct">,</span>
        }
    }
    else if (Node.NodeType == JsonNodeType.Number)
    {
        <span class="json-number">@Node.StringValue</span>
        @if (!IsLast)
        {
            <span class="json-punct">,</span>
        }
    }
    else if (Node.NodeType == JsonNodeType.Boolean)
    {
        <span class="json-boolean">@Node.StringValue</span>
        @if (!IsLast)
        {
            <span class="json-punct">,</span>
        }
    }
    else
    {
        <span class="json-null">null</span>
        @if (!IsLast)
        {
            <span class="json-punct">,</span>
        }
    }
</div>

@if (IsCollapsible && !Node.IsCollapsed && Node.Children.Count > 0)
{
    @for (int i = 0; i < Node.Children.Count; i++)
    {
        var child = Node.Children[i];
        var childIsLast = i == Node.Children.Count - 1;
        <JsonEditorNode Node="@child" Depth="@(Depth + 1)" IsLast="@childIsLast" />
    }
    <div class="json-line">
        <span class="json-indent" style="padding-left: @IndentPx"></span>
        <span class="json-toggle-spacer"></span>
        <span class="json-punct">@CloseBracket</span>
        @if (!IsLast)
        {
            <span class="json-punct">,</span>
        }
    </div>
}

@code {
    [Parameter] public required JsonTreeNode Node { get; set; }
    [Parameter] public int Depth { get; set; } = 0;
    [Parameter] public bool IsLast { get; set; } = true;

    private bool IsCollapsible => Node.NodeType is JsonNodeType.Object or JsonNodeType.Array;
    private string OpenBracket => Node.NodeType == JsonNodeType.Object ? "{" : "[";
    private string CloseBracket => Node.NodeType == JsonNodeType.Object ? "}" : "]";
    private string IndentPx => $"{Depth * 1.5}rem";

    private void ToggleCollapse() => Node.IsCollapsed = !Node.IsCollapsed;
}
